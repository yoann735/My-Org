# Sync Supabase (optionnelle) — partagée par MealWeek ET MedRevise (même projet,
# tables séparées). Copie ce fichier en `.env` et remplis-le.
# Sans ces variables, les deux apps tournent 100 % en local. Voir MEALWEEK_SUPABASE_SYNC.md
# et MEDREVISE_SUPABASE_SYNC.md.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Curation des actus (My Org > News, /api/news.js) — optionnelle.
# Var SERVEUR uniquement (jamais VITE_, donc jamais exposée au front).
# Sans clé : fallback local (tri par date + filtre mots-clés), l'app reste fonctionnelle.
ANTHROPIC_API_KEY=
